    for \(var j = 0; j < 16; j++\) out.push\(p[j] ^ prev[j]\);
    prev = blk;
  }
  return out;
}

function b64e\(a\) {
  var T = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/';
  var r = '', i = 0;
